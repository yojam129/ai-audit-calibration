# Copy to .env.local and fill locally. Never commit .env.local.
INFRA_HOST=192.168.1.4
MYSQL_HOST=192.168.1.4
MYSQL_PORT=3306
MYSQL_USERNAME=root
MYSQL_PASSWORD=
DRUID_MAX_WAIT=30000
DRUID_CONNECT_TIMEOUT=30000
SPRING_DATASOURCE_TYPE=com.alibaba.druid.pool.DruidDataSource
SPRING_DATASOURCE_DRUID_INITIAL_SIZE=0
SPRING_DATASOURCE_DRUID_MIN_IDLE=0
SPRING_DATASOURCE_DRUID_MAX_ACTIVE=4
SPRING_DATASOURCE_DRUID_MAX_WAIT=5000
SPRING_DATASOURCE_DRUID_VALIDATION_QUERY=SELECT 1
SPRING_DATASOURCE_DRUID_TEST_WHILE_IDLE=true
REDIS_HOST=192.168.1.4
REDIS_PORT=6379
REDIS_PASSWORD=
RABBITMQ_HOST=192.168.1.4
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=
RABBITMQ_PASSWORD=
MONGODB_HOST=192.168.1.4
MONGODB_PORT=27017
SIGNAL_MONGODB_URI=mongodb://user:password@192.168.1.4:27017/ai_audit_signal?authSource=admin
NACOS_ADDR=192.168.1.4:8848
NACOS_USERNAME=
NACOS_PASSWORD=
NACOS_NAMESPACE=
NACOS_GROUP=AI_AUDIT
SENTINEL_DASHBOARD=192.168.1.4:8080
MINIO_ENDPOINT=http://192.168.1.4:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
ELASTICSEARCH_URIS=http://192.168.1.4:9200
TRACE_ES_ENABLED=true
FLOWABLE_SCHEMA_UPDATE=true
FLOWABLE_REST_URL=http://192.168.1.4:8090/flowable-ui/process-api
FLOWABLE_REST_USERNAME=
FLOWABLE_REST_PASSWORD=
FLOWABLE_PROCESS_VERSION=2
FLOWABLE_IMPORT_PROCESS_VERSION=1
FLOWABLE_LEARNING_PROCESS_VERSION=1
# Address that the Linux Flowable host can use to call learning-service.
LEARNING_WORKFLOW_CALLBACK_URL=http://YOUR_WINDOWS_LAN_IP:18091
XXL_JOB_ADMIN=http://192.168.1.4:9080/xxl-job-admin
XXL_JOB_ACCESS_TOKEN=default_token
XXL_JOB_EXECUTOR_IP=192.168.1.6
XXL_JOB_EXECUTOR_PORT=9999
JWT_SECRET=
JWT_ISSUER=ai-audit-auth
INTERNAL_CALL_ENABLED=true
INTERNAL_CALL_SECRET=
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MODEL_PATH=
MODEL_VERSION=
MODEL_SHA256=
MODEL_REGISTRY_URL=http://localhost:18094
MODEL_CODE=curve-classifier
STRUCTURED_MODEL_CODE=structured-classifier
STRUCTURED_MODEL_PATH=
STRUCTURED_MODEL_VERSION=
STRUCTURED_MODEL_SHA256=
STRUCTURED_MODEL_WEIGHT=0.25
AI_MODEL_CODE=curve-classifier
AI_INFERENCE_BASE_URL=http://localhost:18000
AI_TRAINING_BASE_URL=http://localhost:18000
AI_TRAINING_TIMEOUT=30m
AI_TRAINING_WINDOW=7d
AI_TRAINING_MIN_SAMPLES=5
AI_TRAINING_AUTO_ACTIVATE=true
AI_TRAINING_TRAFFIC_PERCENT=100
AI_TRAINING_SCHEDULE_ENABLED=false
AI_TRAINING_CRON=0 0 2 * * *
AI_TRAINING_ZONE=Asia/Shanghai
